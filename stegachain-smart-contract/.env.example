# Environment variables for StegaChain smart contract deployment
# Copy this file to .env and fill in your values — NEVER commit .env to git

# RPC endpoint for BSC Testnet (e.g. from Binance or providers like Infura)
BSC_TESTNET_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org/

# Private key of the deployer wallet (no 0x prefix required by Hardhat)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# BscScan API key for contract verification
BSCSCAN_API_KEY=your_bscscan_api_key_here
